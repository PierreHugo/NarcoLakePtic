# NarcoLakePtic - Environment Configuration

# MinIO (S3-compatible object storage for Raw zone)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw
MINIO_SECURE=false

# openFDA API (optional - public API works without key, but rate limited)
# Get a free key at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000

# Data paths (local staging/curated)
DATA_RAW_PATH=data/raw
DATA_STAGING_PATH=data/staging
DATA_CURATED_PATH=data/curated

# Logging
LOG_LEVEL=INFO

# Airflow (for local development with external Airflow)
AIRFLOW_HOME=~/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-change-in-production